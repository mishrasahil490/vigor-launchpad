# ── Backend API URL (set this in Vercel frontend project env vars) ───────────
# Leave blank for local dev (Vite proxy handles it automatically)
VITE_API_URL=https://your-backend.vercel.app

# ── Supabase Realtime (set these in Vercel frontend project env vars) ─────────
# Use the ANON (public) key — NOT the service role key
# Get both from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key-here
