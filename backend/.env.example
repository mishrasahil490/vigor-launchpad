# Server Configuration
PORT=5050

# JWT Secret (change this to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-here

# Supabase Configurations
# Get these from your Supabase project dashboard: https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-here

# Frontend URL (used for CORS and password reset email redirect links)
# Set this to your deployed frontend Vercel URL in production
SITE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
